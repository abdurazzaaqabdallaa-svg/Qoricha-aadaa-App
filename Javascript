function agarsiisiBiqiltoota(data) {
    const listContainer = document.getElementById('biqiltuuList');
    listContainer.innerHTML = ''; 

    data.forEach(biqiltuu => {
        const card = `
            <div class="card">
                <h3>${biqiltuu.maqaa}</h3>
                <p><strong>Maqaa Saayinsii:</strong> <i>${biqiltuu.saayinsii}</i></p>
                <p><strong>Faayidaa:</strong> ${biqiltuu.faayidaa}</p>
                <p><strong>Haala Ittifayyadamaa:</strong> ${biqiltuu.qophii}</p>
            </div>
        `;
        listContainer.innerHTML += card;
    });
}

// Hojii Barbaachaa (Search)
function barbaadiBiqiltuu() {
    const query = document.getElementById('searchInput').value.toLowerCase();
    const filtered = biqiltoota.filter(b => 
        b.maqaa.toLowerCase().includes(query) || 
        b.faayidaa.toLowerCase().includes(query)
    );
    agarsiisiBiqiltoota(filtered);
}

// Yeroo Appiin banamu jalqaba hunda agarsiisi
window.onload = () => agarsiisiBiqiltoota(biqiltoota);
