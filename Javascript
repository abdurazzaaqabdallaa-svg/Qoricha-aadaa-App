function agarsiisiQorichoota(data) {
    const listContainer = document.getElementById('biqiltuuList');
    if (!listContainer) return; 
    
    let htmlContent = ''; 

    data.forEach(item => {
        htmlContent += `
            <div class="card">
                <h3>${item.maqaa}</h3>
                <p><strong>Faayidaa:</strong> ${item.faayidaa}</p>
                <p><strong>Haala Ittifayyadamaa:</strong> ${item.haala}</p>
            </div>
        `;
    });
    
    listContainer.innerHTML = htmlContent; 
}

// Hojii Barbaachaa (Search)
function barbaadiBiqiltuu() {
    const query = document.getElementById('searchInput').value.toLowerCase();
    const filtered = xibbNabawiiData.filter(b => 
        b.maqaa.toLowerCase().includes(query) || 
        b.faayidaa.toLowerCase().includes(query)
    );
    agarsiisiQorichoota(filtered);
}

// Yeroo Appiin guutummaatti banamu jalqaba hunda agarsiisi
document.addEventListener('DOMContentLoaded', () => {
    agarsiisiQorichoota(xibbNabawiiData);
});
